<!--pages/blank/blank.wxml-->
<view style="display: flex; flex-direction: column; min-height: 100vh; background: #fdfcf8; padding: 120rpx 40rpx 60rpx; box-sizing: border-box;">
  
  <view style="font-size: 40rpx; font-weight: bold; margin-bottom: 40rpx;">写日记</view>

  <scroll-view scroll-y style="flex: 1;">
    <picker mode="date" value="{{date}}" bindchange="onDateChange">
      <view style="background: #fff; padding: 30rpx; border-radius: 20rpx; margin-bottom: 20rpx;">📅 日期：{{date}}</view>
    </picker>

    <view style="background: #fff; padding: 30rpx; border-radius: 20rpx; margin-bottom: 20rpx; display: flex; align-items: center;">
      <text style="color: #666; margin-right: 20rpx;"># 标签</text>
      <input style="flex: 1;" placeholder="输入标签(如:小狗)" bindinput="onTagInput" value="{{tag}}"/>
    </view>

    <textarea style="background: #fff; width: 100%; height: 300rpx; padding: 30rpx; border-radius: 20rpx; margin-bottom: 20rpx; box-sizing: border-box;" 
              placeholder="今天发生了什么？" bindinput="onContentInput"></textarea>

    <view bindtap="onChooseImage" style="background: #fff; padding: 30rpx; border-radius: 20rpx; margin-bottom: 40rpx; border: 2rpx dashed #ccc; text-align: center;">
      <view wx:if="{{tempImages.length === 0}}">📸 点击添加图片</view>
      <view wx:else style="display: flex; gap: 10rpx; flex-wrap: wrap;">
        <image wx:for="{{tempImages}}" wx:key="*this" src="{{item}}" style="width: 150rpx; height: 150rpx; border-radius: 10rpx;"></image>
      </view>
    </view>
  </scroll-view>

  <view bindtap="saveAndUpload" style="background: #333; color: #fff; height: 100rpx; border-radius: 50rpx; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 32rpx; box-shadow: 0 10rpx 20rpx rgba(0,0,0,0.1);">
    保存并发布
  </view>
</view>